# Pocket Lawyer 2.0 - Configuration Example
# Copy this file to .env and fill in your actual API keys.

# AI Provider Configuration
# Supported: gemini, openai, anthropic
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# JWT Authentication
JWT_SECRET=replace-this-with-a-very-long-random-string
JWT_EXPIRY_HOURS=24

# LegalDesk (SignDesk / Melento) API Settings
MELENTO_CLIENT_ID=your_client_id_here
MELENTO_API_KEY=your_api_key_here

# Server Configuration
FLASK_DEBUG=true
PORT=5000
HOST=0.0.0.0
